# ── Sensitive / secrets ─────────────────────────────────────────────────────
# NOTE: git does not support inline (end-of-line) comments — each comment must
# be on its own line, or the pattern is read literally and never matches.
# contains API keys — copy from config.json.template
config.json
# GCP service account / ADC JSON
secrets/
# NAS host/user — copy from nas.env.example
nas/nas.env

# ── Runtime data (regenerated on each run) ───────────────────────────────────
data/
logs/

# ── Scraped X posts (regenerated via: python distill.py --refresh) ───────────
creators/*/posts_raw.txt

# ── Amendment drafts (local to your review workflow) ─────────────────────────
creators/*/amendments/

# ── Python build artifacts ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ── Editor ───────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
